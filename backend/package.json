{
  "name": "taskforge-backend",
  "version": "0.1.0",
  "description": "TaskForge — multi-tenant project management API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "migration:run:prod": "node scripts/migrate-prod.cjs",
    "start:prod:with-migrations": "node scripts/migrate-prod.cjs && node dist/main",
    "start:worker": "node dist/worker",
    "start:worker:dev": "nest start --watch --entryFile worker",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "ci:local": "npm run lint:check && npm audit --audit-level=high && npm test && npm run build && node scripts/verify-build.mjs",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:generate": "npm run typeorm -- migration:generate -d src/infrastructure/database/typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/infrastructure/database/typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/infrastructure/database/typeorm.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "argon2": "^0.44.0",
    "bullmq": "^5.75.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "typescript-eslint": "^8.46.4"
  }
}
