# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=taskforge
# Neon / cloud Postgres (required when not using local Docker):
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# If the app cannot verify the server cert, last resort (weaker):
# DB_SSL_REJECT_UNAUTHORIZED=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true

# Auth (JWT_SECRET must be at least 32 characters)
JWT_SECRET=your-secret-key-change-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Stripe (optional until you use billing webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
FRONTEND_URL=http://localhost:3000

# Email (SMTP) — Gmail example (use App Password for SMTP_PASS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TaskForge <noreply@taskforge.io>
