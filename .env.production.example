# Image tag to deploy (git sha from GHCR, e.g. sha-abc1234)
TAG=latest

# Database (Neon: use pooler host from dashboard; set DB_SSL=true)
DB_HOST=ep-xxxxx.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neon_owner_or_role
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=neondb
DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Redis (Upstash etc.: set REDIS_TLS=true and REDIS_PASSWORD)
REDIS_HOST=
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=true

# Auth (must be at least 32 characters)
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET_KEY_HERE
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# Frontend
FRONTEND_URL=http://localhost
